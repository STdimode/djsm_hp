@{
    string layoutPath = "/UserData/djsmchurch/Layouts/djsmchurch_Layout";
    string cssFile = layoutPath + "/Contents/Main_v1.css";
    string jsFile = layoutPath + "/Scripts/Main_v1.js";
    // 로컬 전환용 주석 (필요 시 해제)
    // string localFontCss = layoutPath + "/Contents/fonts.css";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
@* <link href="@Url.Content("~" + localFontCss)" rel="stylesheet" /> *@
<link href="@Url.Content("~" + cssFile)" rel="stylesheet" />

<div class="cms-content-root">
    <div class="app-container">
        <!-- ━━━ HERO ━━━ -->
        <section class="hero-section">
            <!-- Crossfade background images -->
            <div class="hero-image hero-image-active" style="background-image: url('/UserData/djsmchurch/Layouts/djsmchurch_Layout/images/1_slider.jpg');"></div>
            <!-- dots - hidden when single image -->
        </section>

        <!-- ━━━ WELCOME ━━━ -->
        <section class="welcome-section">
            <div class="welcome-container">
                <div class="fade-up">
                    <div class="welcome-text-container">
                        <div class="welcome-bar"></div>
                        <h2 class="welcome-title">welcome</h2>
                        <p class="welcome-desc">하나님의 뜻을 이루는 교회,​<br>대전서문교회에 오신것을 환영합니다.</p>
                    </div>
                </div>

                <div class="fade-up" data-delay="150">
                    <div class="welcome-cards-container">
                        <div class="welcome-cards-grid">
                            <div class="welcome-card">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none" stroke="#555" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21.5 8v27M15 20h13"></path>
                                    <path d="M15.5 14l-3-3M27.5 14l3-3"></path>
                                    <path d="M15.5 28.5l-3 3M27.5 28.5l3 3"></path>
                                    <path d="M10.5 21.5l-3 0M35.5 21.5l-3 0"></path>
                                </svg>
                                <span class="welcome-card-label">비전 나눔</span>
                            </div>
                            <div class="welcome-card">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none" stroke="#555" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="7" y="12" width="29" height="20" rx="1.5"></rect>
                                    <path d="M7 14l14.5 11L36 14"></path>
                                </svg>
                                <span class="welcome-card-label">인사말씀</span>
                            </div>
                            <div class="welcome-card">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none" stroke="#555" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="10" y="6" width="23" height="31" rx="2"></rect>
                                    <path d="M10 31h23"></path>
                                    <path d="M21.5 12v12M17.5 18h8"></path>
                                </svg>
                                <span class="welcome-card-label">예배안내</span>
                            </div>
                            <div class="welcome-card">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none" stroke="#555" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="17" cy="14" r="5"></circle>
                                    <path d="M7 36c0-6 4-10 10-10s10 4 10 10"></path>
                                    <path d="M32 16c-1.5-1.5-3.5-1.5-5 0-1.5 1.5-1.5 3.5 0 5l5 5 5-5c1.5-1.5 1.5-3.5 0-5-1.5-1.5-3.5-1.5-5 0z"></path>
                                </svg>
                                <span class="welcome-card-label">교회섬김</span>
                            </div>
                            <div class="welcome-card">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none" stroke="#555" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21.5 6C16 6 12 10.5 12 16c0 8 9.5 19 9.5 19S31 24 31 16c0-5.5-4-10-9.5-10z"></path>
                                    <circle cx="21.5" cy="16" r="3.5"></circle>
                                </svg>
                                <span class="welcome-card-label">오시는 길</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ━━━ THREE CARDS ━━━ -->
        <section class="three-cards-section" >
            <div class="three-cards-container">
                <!-- Card 1 -->
                <div class="fade-up" data-delay="0">
                    <div class="three-card card-1-bg">
                        <div class="three-card-overlay card-1-overlay"></div>
                        <div class="three-card-content">
                            <div>
                                <span class="three-card-badge">주일오전예배 Sunday worship</span>
                                <h3 class="three-card-title desktop-only">설교제목입니다.</h3>
                                <h3 class="three-card-title-mobile mobile-only">설교제목입니다.</h3>
                                <p class="three-card-subtitle">시편 131:1-3 | 김용환 목사</p>
                                <p class="three-card-date">2026.03.08</p>
                            </div>
                        </div>
                        <div class="three-card-arrow">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 11L11 1M11 1H3M11 1v8"></path>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="fade-up" data-delay="120">
                    <div class="three-card card-2-bg">
                        <div class="three-card-overlay card-2-overlay"></div>
                        <div class="three-card-content">
                            <div>
                                <span class="three-card-badge">주일오후예배 Sunday worship</span>
                                <h3 class="three-card-title desktop-only">설교제목입니다.</h3>
                                <h3 class="three-card-title-mobile mobile-only">설교제목입니다.</h3>
                                <p class="three-card-subtitle">시편 131:1-3 | 김용환 목사</p>
                                <p class="three-card-date">2026.03.08</p>
                            </div>
                        </div>
                        <div class="three-card-arrow">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 11L11 1M11 1H3M11 1v8"></path>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="fade-up" data-delay="240">
                    <div class="three-card card-3-bg">
                        <div class="three-card-overlay card-3-overlay"></div>
                        <div class="three-card-content">
                            <div>
                                <span class="three-card-badge">수요예배 Wednesday worship</span>
                                <h3 class="three-card-title desktop-only">설교 제목입니다.</h3>
                                <h3 class="three-card-title-mobile mobile-only">설교 제목입니다.</h3>
                                <p class="three-card-subtitle">시편 131:1-3 | 김용환 목사</p>
                                <p class="three-card-date">2026.03.08</p>
                            </div>
                        </div>
                        <div class="three-card-arrow">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 11L11 1M11 1H3M11 1v8"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ━━━ CHURCH SCHOOL ━━━ -->
        <section class="church-school-section" style="background-image: url('/UserData/djsmchurch/Layouts/djsmchurch_Layout/images/nxt_bg.jpg');">
            <div class="church-school-overlay"></div>
            <div class="church-school-container">
                <div class="fade-up">
                    <h2 class="church-school-title">대전서문교회 다음세대</h2>
                    <p class="church-school-desc">하나님을 바르게 알고 성장하며<br> 신앙과 삶을 연결하도록 돕습니다.</p>
                </div>

                <div class="church-school-grid">
                    <!-- School Card 1 -->
                    <div class="fade-up church-school-fade-wrapper" data-delay="0">
                        <div class="school-card">
                            <div class="school-card-icon">
                                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#334" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="school-card-svg">
                                    <path d="M24 40V24"></path>
                                    <path d="M24 24c0 0-1-10 -10-12 0 8 4 12 10 12z"></path>
                                    <path d="M24 28c0 0 1-8 9-10 0 7-3 11-9 10z"></path>
                                    <path d="M24 40c0 0-4 0-6 0"></path>
                                </svg>
                            </div>
                            <h4 class="school-card-title">유아부</h4>
                            <p class="school-card-desc desktop-only">말씀 안에 쑥쑥<br>자라나는 유아부</p>
                        </div>
                    </div>

                    <!-- School Card 2 -->
                    <div class="fade-up church-school-fade-wrapper" data-delay="120">
                        <div class="school-card">
                            <div class="school-card-icon">
                                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#334" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="school-card-svg">
                                    <circle cx="24" cy="18" r="10"></circle>
                                    <path d="M24 8l2.5 5 5.5.8-4 3.9.9 5.5L24 21l-4.9 2.6.9-5.5-4-3.9 5.5-.8z"></path>
                                    <path d="M17 26l-3 12 10-4 10 4-3-12"></path>
                                </svg>
                            </div>
                            <h4 class="school-card-title">어와나소년부</h4>
                            <p class="school-card-desc desktop-only">하나님의 일꾼으로<br>성장하는 어와나소년부</p>
                        </div>
                    </div>

                    <!-- School Card 3 -->
                    <div class="fade-up church-school-fade-wrapper" data-delay="240">
                        <div class="school-card">
                            <div class="school-card-icon">
                                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#334" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="school-card-svg">
                                    <path d="M24,7 L35,24 L30,24 L39,36 L27,36 L27,43 L21,43 L21,36 L9,36 L18,24 L13,24 Z"></path>
                                </svg>
                            </div>
                            <h4 class="school-card-title">청소년부</h4>
                            <p class="school-card-desc desktop-only">신앙을 바탕으로 성장하며<br>하나님과 관계를 깊이 맺는 청소년부</p>
                        </div>
                    </div>

                    <!-- School Card 4 -->
                    <div class="fade-up church-school-fade-wrapper" data-delay="360">
                        <div class="school-card">
                            <div class="school-card-icon">
                                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#334" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="school-card-svg">
                                    <path d="M24 6c0 8-8 12-8 20a8 8 0 0016 0c0-4-3-7-3-12-2 3-3 5-3 8a4 4 0 01-8 0c0-5 6-9 6-16z"></path>
                                </svg>
                            </div>
                            <h4 class="school-card-title">청년부</h4>
                            <p class="school-card-desc desktop-only">빛과 소금으로<br>살아가려 힘쓰는 청년부</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ━━━ GALLERY ━━━ -->
        <section class="gallery-section">
            <div class="gallery-container">
                <div class="fade-up">
                    <h2 class="gallery-title">gallery</h2>
                </div>

                <!-- Full-width carousel container -->
                <div class="gallery-carousel-wrapper" id="galleryContainer">
                    <div class="gallery-carousel-track" id="galleryTrack">
                        <!-- JS will inject slides here -->
                    </div>
                </div>

                <!-- controls — arrows at far left/right, dots centered -->
                <div class="gallery-controls">
                    <!-- left arrow -->
                    <button class="gallery-btn-prev" id="galleryPrev">
                        <svg class="gallery-arrow-svg gallery-arrow-left" viewBox="0 0 160 20" fill="none" preserveAspectRatio="xMinYMid meet">
                            <line x1="160" y1="10" x2="4" y2="10" stroke="#bbb" stroke-width="1.2"></line>
                            <polyline points="12,3 4,10 12,17" stroke="#bbb" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>
                        </svg>
                    </button>

                    <!-- dots -->
                    <div class="gallery-dots" id="galleryDots">
                        <!-- JS will inject dots here -->
                    </div>

                    <!-- right arrow -->
                    <button class="gallery-btn-next" id="galleryNext">
                        <svg class="gallery-arrow-svg gallery-arrow-right" viewBox="0 0 160 20" fill="none" preserveAspectRatio="xMaxYMid meet">
                            <line x1="0" y1="10" x2="156" y2="10" stroke="#bbb" stroke-width="1.2"></line>
                            <polyline points="148,3 156,10 148,17" stroke="#bbb" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>
                        </svg>
                    </button>
                </div>
            </div>
        </section>

    </div>
</div>

<script src="@Url.Content("~" + jsFile)"></script>